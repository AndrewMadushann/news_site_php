# ──────────────────────────────────────────────────────────
# Environment configuration template.
# Copy this file to `.env` and fill in real values.
# `.env` is git-ignored so secrets never reach the repo.
# ──────────────────────────────────────────────────────────

# Database
DB_HOST=localhost
DB_PORT=3306
DB_NAME=news_db
DB_USER=root
DB_PASS=

# TinyMCE — cloud-hosted rich-text editor
# Get your own free key at: https://www.tiny.cloud/my-account/integrate/cloud-based/
TINYMCE_API_KEY=no-api-key
